df_wide
Program  <- c(1.01, 0.98, 0.25, -0.01, 1.32, 1.09, 0.53, 0.63, 2.11, 0.12)
Control  <- c(-0.51, 0.23, 0.41, 0.04, -0.06, -0.13, 0.00, 1.02, 0.34, 1.32)
# Combine into a tidy data frame (optional but nice)
df <- data.frame(
Group = rep(c("Program", "Control"), each = 10),
Score = c(Program, Control)
)
# Independent samples t-test
t.test(Score ~ Group, data = df, var.equal = FALSE)   # Welch t-test (default)
t.test(Score ~ Group, data = df, var.equal = TRUE)
View(df)
