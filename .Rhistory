## Create data set ####
cattle <- read.csv("https://byu.box.com/shared/static/kg2c019hisr10c2k2fgi6btz9s633qna.csv")
cattle$sire <- factor(cattle$sire)
View(cattle)
## Visualize data
boxplot(weight ~ sire, data = cattle)
## lme4 package allows us to use REML
library(lme4)
## Fit a random effects model
fit.cattle <- lmer(weight ~ (1 | sire), data = cattle)
summary(fit.cattle)
options(contrasts = c("contr.sum", "contr.poly"))
fit.cattle.lm <- lm(weight ~ sire, data = cattle)
confint(fit.cattle.lm)
ranef(fit.cattle)
plot(fit.cattle) ## Equal variance plot
qqnorm(residuals(fit.cattle))
qqline(residuals(fit.cattle))
