plot(emm.project)
# Here is the code used to visualize my data
interaction.plot(x.factor  = STAT_230_Project_Z$Bottle,
trace.factor = STAT_230_Project_Z$Water,
response = STAT_230_Project_Z$Temp,
col = c("blue", "red"),
lty = 1,
lwd = 2,
xlab = "Bottle type",
ylab = "Emmean Temp Change (°F))",
trace.label = "Water Temp")
# Here is the code usted to analyze my data
anova(fit.project)
summary(fit.project)
library(emmeans)
emmeans(fit.project, pairwise ~ Bottle)
emmeans(fit.project, pairwise ~ Water)
emm.comb <- emmeans(fit.project, specs = ~ Bottle|Water)
contrast(emm.comb, method = "pairwise")
# Create a key, then assign bottle size as a new column
# Bottle sizes were found by examing the manufacturer’s specifications
bottle_size <- c(`Owala` = 24,
`Stanley` = 40,
`Nike` = 32,
`Iron Flask` = 22,
`Thermoflask` = 40)
STAT_230_Project_Z$Size <- bottle_size[STAT_230_Project_Z$Bottle]
# Run ANCOVA
fit_ancova <- lm(Temp ~ Water * Bottle + Size, data = STAT_230_Project_Z)
anova(fit_ancova)
library(pwr2)
sig <- sqrt(1.38)
tmeans <- tapply(STAT_230_Project_Z$Temp,
list(STAT_230_Project_Z$Bottle, STAT_230_Project_Z$Water),
mean)
tmeans <- as.matrix(tmeans)
# 3. Compute effect sizes
# Factor A = rows (Bottle)
means_A <- rowMeans(tmeans, na.rm = TRUE)
A <- sqrt(var(means_A) / sig^2)
# Factor B = columns (Water)
means_B <- colMeans(tmeans, na.rm = TRUE)
B <- sqrt(var(means_B) / sig^2)
result <- pwr.2way(a=5, b=2, alpha= .05, size.A=4, size.B=4, f.A=A, f.B=B, delta.A=NULL, delta.B=NULL)
result
# Install Superpower if not already installed
library(Superpower)
# 1. Compute cell means from your data
# Bottle = factor A, Water = factor B
tmeans <- tapply(STAT_230_Project_Z$Temp,
list(STAT_230_Project_Z$Bottle, STAT_230_Project_Z$Water),
mean)
tmeans <- as.matrix(tmeans)
# 2. Convert cell means to vector for Superpower (row-major)
mu <- as.vector(t(tmeans))
# 3. Set pooled standard deviation
sd <- sqrt(1.38)  # Replace with your actual pooled SD if different
# 4. Number of replicates per cell
n <- 4
# 5. Number of levels for each factor
a <- nrow(tmeans)  # Bottle
b <- ncol(tmeans)  # Water
# 6. Define ANOVA design
# Replace "w" and "b" with correct within/between designation
design <- ANOVA_design(
design = paste0(a, "w*", b, "b"),  # e.g., "5w*2b"
n = n,
mu = mu,
sd = sd
)
# 7. Run power analysis (simulation)
power_results <- ANOVA_power(design, alpha = 0.05, nsims = 10000)
help("ANOVA_power")
