library(lmerTest)
Plumb$orchard <- as.factor(Plumb$orchard)
Plumb$spray   <- as.factor(Plumb$spray)
Plumb$pruning <- as.factor(Plumb$pruning)
plumb.fit <- lmer(
weight ~ spray * pruning + (1 | orchard) + (1 | spray:pruning),
data = Plumb
)
anova(plumb.fit)
plumb.fit <- lmer(weight ~ (1 | orchard) + spray + pruning + spray * pruning + (1 | spray:pruning), data = Plumb)
anova(plumb.fit)
